# AgentForge Local Backend Configuration
# ========================================

# MongoDB - Use local or free cloud (MongoDB Atlas)
# Option 1: Local MongoDB (if installed)
MONGO_URL=mongodb://localhost:27017
DB_NAME=agentforge

# Option 2: Free MongoDB Atlas (sign up at mongodb.com/atlas)
# MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net
# DB_NAME=agentforge

# Server
HOST=0.0.0.0
PORT=8001

# Optional: Add your API keys for full functionality
# FAL_KEY=your_fal_api_key
# OPENAI_API_KEY=your_openai_key
# ELEVENLABS_API_KEY=your_elevenlabs_key
